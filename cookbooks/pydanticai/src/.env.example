# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-key-here

# Optioneel: override het model (default: gpt-5.4-mini)
# OPENAI_MODEL=gpt-5.4-mini

# Optioneel: deep-tracing via Pydantic Logfire.
# Vereist `logfire` in requirements.txt; daarna logt elke call naar Logfire.
# LOGFIRE_TOKEN=your-logfire-token
