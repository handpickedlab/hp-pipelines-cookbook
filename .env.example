# Kopieer naar .env (of naar cookbooks/<slug>/src/.env) en vul in.
# .env-bestanden zijn ge-gitignored — alleen dit example-bestand hoort in de repo.
# Voor gedeployde cookbooks: zet deze als env vars in de Vercel project settings.

# Of stuur berichtje naar Niek voor API keys


# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Claude (Anthropic) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
